# ── ELS 플랫폼 환경변수 템플릿 ──
# 이 파일을 복사해 .env 로 만들고 실제 값을 채우세요. (.env 는 커밋되지 않습니다)
#   cp .env.example .env

# Django 시크릿 키 — 아래 명령으로 생성:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=

# 로컬 개발은 1, 외부 노출(운영)은 0
DJANGO_DEBUG=1

# 접속 허용 호스트 (콤마 구분). 터널 도메인 추가 시 여기에.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# 터널 https 도메인 (CSRF 신뢰). 예: https://els.example.com
DJANGO_CSRF_TRUSTED=

# ELS_Curator exe 가 엑셀을 만드는 폴더 (기본값은 settings.py 참고)
ELS_DOWNLOADS_DIR=

# 텔레그램 봇 (BotFather 토큰 / @userinfobot 에서 chat id)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
